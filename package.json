{
  "name": "@dejwcake/craftable",
  "version": "1.0.0",
  "description": "This is a frontend dependency for Craftable. Craftable is a Laravel-based open-source toolkit for building administration interfaces.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./scss/*": "./scss/*"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "lint:style": "stylelint \"scss/**/*.scss\"",
    "lint:style:fix": "stylelint \"scss/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{js,vue}\" \"scss/**/*.scss\"",
    "format:check": "prettier --check \"src/**/*.{js,vue}\" \"scss/**/*.scss\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dejwCake/craftable-frontend.git"
  },
  "author": "Brackets",
  "contributors": [
    "David Behal <david.behal@dejw.sk>"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dejwCake/craftable-frontend/issues"
  },
  "homepage": "https://github.com/dejwCake/craftable-frontend#readme",
  "dependencies": {
    "@ckeditor/ckeditor5-vue": "^7.3.1",
    "@coreui/coreui": "^5.3",
    "@fortawesome/fontawesome-free": "^7.2",
    "@kyvg/vue3-notification": "^3.4",
    "@tiptap/extension-image": "^2.11",
    "@tiptap/extension-link": "^2.11",
    "@tiptap/extension-table": "^2.11",
    "@tiptap/extension-table-cell": "^2.11",
    "@tiptap/extension-table-header": "^2.11",
    "@tiptap/extension-table-row": "^2.11",
    "@tiptap/starter-kit": "^2.11",
    "@tiptap/vue-3": "^2.11",
    "@vee-validate/i18n": "^4.15",
    "@vee-validate/rules": "^4.15",
    "@vuepic/vue-datepicker": "^12.1",
    "axios": "^1.9",
    "bootstrap": "^5.3",
    "ckeditor5": "^47.5.0",
    "date-fns": "^4.1",
    "dayjs": "^1.11",
    "vee-validate": "^4.15",
    "vue": "^3.5",
    "vue-multiselect": "^3.2",
    "vue3-cookies": "^1.0",
    "vue3-dropzone": "^2.2",
    "vue3-popper": "^1.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "autoprefixer": "^10.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.85",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^14.0.0",
    "vite": "^6.3"
  },
  "bin": {
    "craftable-publish-components": "./scripts/publish-components.js"
  },
  "files": [
    "/dist",
    "/img",
    "/scss",
    "/scripts",
    "/src"
  ]
}
